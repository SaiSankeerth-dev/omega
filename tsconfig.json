{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitAny": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@omega/shared": ["./packages/shared/src"],
      "@omega/ui": ["./packages/ui/src"],
      "@omega/config": ["./packages/config/src"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "store/**/*.ts",
    "lib/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": ["node_modules", ".next", "dist"]
}
