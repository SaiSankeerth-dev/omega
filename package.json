{
  "name": "omega",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,server -c cyan,green \"npm run dev -w web\" \"npm run dev -w server\"",
    "dev:web": "npm run dev -w web",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w web && npm run build -w server",
    "build:web": "npm run build -w web",
    "build:server": "npm run build -w server",
    "start": "npm run start -w web",
    "start:server": "npm run start -w server",
    "lint": "eslint apps packages store lib tests",
    "lint:fix": "eslint apps packages store lib tests --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:workspaces": "npm run typecheck --workspaces",
    "typecheck:all": "npm run typecheck && npm run typecheck:workspaces",
    "db:generate": "prisma generate --schema apps/server/prisma/schema.prisma",
    "db:push": "prisma db push --schema apps/server/prisma/schema.prisma",
    "db:studio": "prisma studio --schema apps/server/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema apps/server/prisma/schema.prisma --name",
    "postinstall": "prisma generate --schema apps/server/prisma/schema.prisma",
    "clean": "rimraf apps/*/dist packages/*/dist coverage node_modules/.cache"
  },
